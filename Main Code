# ---------------------------------------------------------------------------
# DEMO + SELF-TEST
# ---------------------------------------------------------------------------
def _self_test(trials: int = 200) -> None:
    """Confirms the plan() output, when replayed on a simulated cube, actually
    solves it and never turns the forbidden face. Requires pycuber."""
    import random
    import pycuber as pc

    def to_kociemba(cube):
        ctr = {f: cube.get_face(f)[1][1].colour for f in FACES}
        c2f = {ctr[f]: f for f in FACES}
        return "".join(c2f[s.colour] for f in FACES
                       for row in cube.get_face(f) for s in row)

    def solved(cube):  # orientation-independent
        return all(len({s.colour for row in cube.get_face(f) for s in row}) == 1
                   for f in FACES)

    suffix = {1: "", -1: "'", 2: "2"}
    good = forbidden_hits = 0
    for _ in range(trials):
        scr = pc.Formula(" ".join(random.choice(FACES) + random.choice(["", "'", "2"])
                                  for _ in range(28)))
        cube = pc.Cube(); cube(scr)
        ops = plan(to_kociemba(cube))
        test = pc.Cube(); test(scr)
        for op in ops:
            if op.kind == "ROTATE":
                test(pc.Formula(op.target))
            else:
                if op.target == FORBIDDEN_FACE:
                    forbidden_hits += 1
                test(pc.Formula(op.target + suffix[op.quarter_turns]))
        good += solved(test)
    print(f"self-test: solved {good}/{trials}, forbidden-face turns = {forbidden_hits}")
    assert good == trials and forbidden_hits == 0, "LOGIC ERROR"


