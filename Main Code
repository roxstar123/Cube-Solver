# ---------------------------------------------------------------------------
# GETTING THE CUBE STATE INTO A KOCIEMBA STRING
# ---------------------------------------------------------------------------
def facelets_from_colors(faces: dict) -> str:
    """faces: {'U': 'WWWWWWWWW', 'R': ..., ...} of color letters (any 6 distinct
    chars). Maps each center color to its face letter and returns the 54-char
    Kociemba string. Use this with a camera/color-sensor scan or manual entry."""
    centers = {f: faces[f][4] for f in FACES}        # index 4 = center sticker
    color_to_face = {centers[f]: f for f in FACES}
    return "".join(color_to_face[c] for f in FACES for c in faces[f])

